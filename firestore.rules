rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    match /registration_requests/{tokenId} {
      allow create: if request.resource.data.email.matches('.*@insel[.]ch$');
      allow read, delete: if true; 
      allow update: if false; 
    }

    match /pages/{pageId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email.matches('.*@insel[.]ch$');
      
      match /history/{historyId} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.token.email.matches('.*@insel[.]ch$');
      }

      match /presence/{sessionId} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.token.email.matches('.*@insel[.]ch$');
      }

      match /yjs_updates/{updateId} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.token.email.matches('.*@insel[.]ch$');
      }

      match /yjs_awareness/{clientId} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.token.email.matches('.*@insel[.]ch$');
      }

      match /yjs_state/{stateId} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.token.email.matches('.*@insel[.]ch$');
      }
    }
  }
}
